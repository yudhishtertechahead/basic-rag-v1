# =============================================================
# .env.example — Copy this to .env and fill in your values
# =============================================================
# To use: cp .env.example .env   (or copy manually on Windows)

# ── Google Gemini (required even for embeddings) ──────────────
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL=gemini-3.5-flash

# ── LLM Provider Toggle ───────────────────────────────────────
# Options: "google" or "ollama"
LLM_PROVIDER=google

# ── Ollama (only needed if LLM_PROVIDER=ollama) ───────────────
# Install from https://ollama.com, then run: ollama pull llama3
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# ── Qdrant Cloud ──────────────────────────────────────────────
# Sign up at https://cloud.qdrant.io (free tier available)
# Get these from your cluster dashboard
QDRANT_URL=https://xxxx.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION=rag_docs

# ── Embedding Model ───────────────────────────────────────────
# Uses Google's embedding model (requires GOOGLE_API_KEY)
EMBEDDING_MODEL=models/text-embedding-004
