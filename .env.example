# =============================================================
# .env.example — Copy this to .env and fill in your values
# =============================================================
# Usage:
#   Windows: copy .env.example .env
#   macOS/Linux: cp .env.example .env
#
# IMPORTANT: Never commit your .env file to Git.
# This .env.example is safe to commit — it contains no real secrets.
# =============================================================

# ── LLM Provider Toggle ───────────────────────────────────────
# Which LLM provider to use: "groq", "google", or "ollama"
# Groq is recommended for local dev (fastest, free tier available)
LLM_PROVIDER=groq

# ── Groq (recommended — fastest, free tier available) ─────────
# Sign up at https://console.groq.com
# Supported models: llama-3.1-8b-instant, llama-3.3-70b-versatile
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.1-8b-instant

# ── Google Gemini ─────────────────────────────────────────────
# Sign up at https://aistudio.google.com
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_MODEL=gemini-2.0-flash

# ── Ollama (local only — no API key needed) ───────────────────
# Install from https://ollama.com, then run: ollama pull llama3
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# ── Qdrant Cloud ──────────────────────────────────────────────
# Sign up at https://cloud.qdrant.io (free tier available)
# QDRANT_URL    → from your cluster dashboard (e.g. https://xxxx.us-east4-0.gcp.cloud.qdrant.io)
# QDRANT_API_KEY → from the API Keys section of your cluster
# QDRANT_COLLECTION → the collection name (like a "table") — created automatically on first ingest
#
# IMPORTANT: Deploy your Qdrant cluster in the same region as your app server
# for lowest latency (e.g., both on AWS us-east-1).
QDRANT_URL=https://your-cluster-id.your-region.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key-here
QDRANT_COLLECTION=rag_docs_v1

# ── Embedding Model ───────────────────────────────────────────
# all-MiniLM-L6-v2: 384-dim, fast CPU inference, no GPU required
# Must match the vector dimension (384) used in your Qdrant collection.
# If you change this, you must re-create the Qdrant collection and re-ingest.
EMBEDDING_MODEL=all-MiniLM-L6-v2
