# =============================================================
# .env.example — Copy this to .env and fill in your values
# =============================================================
# To use: cp .env.example .env   (or copy manually on Windows)

# ── LLM Provider Toggle ───────────────────────────────────────
# Options: "groq", "google", or "ollama"
# Groq with 8b-instant is the fastest option (~1s total)
LLM_PROVIDER=groq

# ── Groq (recommended — fastest, free tier available) ─────────
# Sign up at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# ── Google Gemini (alternative LLM) ──────────────────────────
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL=gemini-2.0-flash

# ── Ollama (only needed if LLM_PROVIDER=ollama) ───────────────
# Install from https://ollama.com, then run: ollama pull llama3
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# ── Qdrant Cloud ──────────────────────────────────────────────
# Sign up at https://cloud.qdrant.io (free tier available)
# Get these from your cluster dashboard
QDRANT_URL=https://xxxx.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION=rag_docs

# ── Embedding Model ───────────────────────────────────────────
# all-MiniLM-L6-v2: 384-dim SentenceTransformer, fast CPU inference
# Matches the vector dimension (384) used in the Qdrant collection
EMBEDDING_MODEL=all-MiniLM-L6-v2
